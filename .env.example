# TENG Smart Parking environment variables

# Demo public access gate
DEMO_USER=teng
DEMO_PASSWORD=change-this-demo-password

# Payment provider
# mock = works immediately for MVP testing
# opn = Opn Payments / Omise PromptPay scaffold
PAYMENT_PROVIDER=mock

# Set after Opn/Omise merchant onboarding and KYC approval.
# Do not commit real keys or upload them to Drive as plain text.
OPN_PUBLIC_KEY=pkey_test_xxx
OPN_SECRET_KEY=skey_test_xxx
OPN_WEBHOOK_SECRET=whsec_xxx

# Admin/manual gate and operations log export.
# Required for /api/gates/:gateId/open and /api/operations/logs(.csv).
ADMIN_GATE_TOKEN=change-this-long-random-token
